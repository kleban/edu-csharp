{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "CityExplorer": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=cityexplorer.db"
  },
  "ExternalApis": {
    "Nominatim": {
      "BaseUrl": "https://nominatim.openstreetmap.org/",
      "TimeoutSeconds": 5,
      "MaxRetryAttempts": 3,
      "BreakDurationSeconds": 10
    },
    "OpenMeteo": {
      "BaseUrl": "https://api.open-meteo.com/",
      "TimeoutSeconds": 5,
      "MaxRetryAttempts": 3,
      "BreakDurationSeconds": 10
    },
    "RestCountries": {
      "BaseUrl": "https://restcountries.com/",
      "TimeoutSeconds": 5,
      "MaxRetryAttempts": 3,
      "BreakDurationSeconds": 10
    }
  }
}
